{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tide",
  "version": "0.1.1",
  "identifier": "com.tide.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tide",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Cross-platform desktop client for InfluxDB 3.x",
    "longDescription": "Tide is a Navicat-style GUI client for InfluxDB 3.x. Browse databases and tables, write SQL with autocomplete, view results in a spreadsheet or line chart, and export to CSV / JSON. Runs 100% locally; tokens stay in your system keychain.",
    "copyright": "",
    "publisher": "Tide",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
